# ═══════════════════════════════════════════════
# VEORI AI — Environment Variables
# Set all of these in Railway dashboard (never commit .env)
# ═══════════════════════════════════════════════

PORT=3001
NODE_ENV=production

# Supabase
SUPABASE_URL=https://xqllxyoeftkbufoungcz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Auth
JWT_SECRET=generate_a_long_random_string_here

# Anthropic — Claude Haiku 4.5
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Vapi — ALL telephony (calls + SMS). No Twilio needed.
VAPI_API_KEY=your_vapi_api_key_here
VAPI_PHONE_NUMBER_ID=your_default_vapi_phone_number_id
VAPI_WEBHOOK_URL=https://your-backend.railway.app/api/vapi/webhook

# ElevenLabs voice
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# CORS — your Vercel frontend URL
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173
